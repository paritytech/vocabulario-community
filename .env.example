# IPFS gateway for retrieving published dictionaries by CID. Default is baked
# into the code, so this is only needed to override. Copy to `.env.local` to use.
VITE_IPFS_GATEWAY=https://paseo-bulletin-next-ipfs.polkadot.io/ipfs/

# Publishing has no config: it runs only inside the Polkadot host, under the
# user's RFC-0010 Bulletin allowance (no dev key, no flag).
